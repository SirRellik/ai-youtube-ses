# YouTube OAuth (SmartEnergyShare channel - DO NOT mix with AETERNA channel)
YT_CLIENT_SECRET_PATH=./data/youtube/client-secret.json
YT_OAUTH_TOKEN_PATH=./data/youtube/youtube-oauth.json
# Article source
SES_API_URL=https://admin.smartenergyshare.com/api/marketing/articles
SES_FALLBACK_DIR=/opt/nyx/nyx-neural-data/satellite-blogs
# Optional image search
PEXELS_API_KEY=
# Premium TTS (narrator-v2): Gemini native TTS, falls back to edge-tts.
# Key also auto-resolved from /opt/nyx/nyx-neural-data/llm-hub.json
GEMINI_API_KEY=
# Optional: Gemini prebuilt voice (Charon=informative, Sulafat=warm, Kore=firm female)
GEMINI_TTS_VOICE=Charon
# Optional: override TTS model (default gemini-2.5-flash-preview-tts, then 3.1 preview)
GEMINI_TTS_MODEL=
# Optional: style instruction prepended to every narration
GEMINI_TTS_STYLE=
# Dashboard
DASHBOARD_PORT=3041
